# llama.cpp server (ROCm) configuration
# Copy to .env and adjust for your host.

# Host directory whose `cache/` subdir is mounted at /root/.cache in the
# container. Covers the HF model cache (~/.cache/huggingface/hub) and the
# llama.cpp prompt cache. Models are downloaded on first start via the
# -hf flag in docker-compose.yml; recreates reuse the cache.
CONFIG_PATH=/home/bowlinedandy/docker-data/llama-cpp
